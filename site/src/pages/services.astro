---
import {services} from "../data/services.js";
import Hero from "../components/Hero.astro";
import Layout from "../layouts/Layout.astro";
---
<Layout>
    <Hero>
        <div class="w-1/2 mx-auto text-white text-center">
            <div class="font-semibold text-4xl mb-5">It’s Not Just Insurance</div>
            <div class="text-2xl">
                The true meaning and value of our work is in providing our clients, their families, and colleagues with
                the
                tools for economic security, quality of life, and priceless peace of mind.
            </div>
        </div>

    </Hero>
    <section class="mb-6">
        {services.map((service, index) => (
                <div class={index % 2 === 0 ? "section-bg-light" : ""}
                     id={service.link}>
                    <div class="w-1/2 mx-auto py-10">
                        <div class="title-color text-5xl text-center">
                            {service.title}
                        </div>
                        <div>
                            {service.image}
                        </div>
                        <div class="title-color text-2xl">
                            {service.subtitle}
                        </div>
                        <div>
                            {service.full_description}
                        </div>
                    </div>
                </div>
        ))}
    </section>
</Layout>
