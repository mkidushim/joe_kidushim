---
// Props for dynamic hero
const { image = 'home-hero.webp' } = Astro.props;
---
<section class="relative w-full h-[50vh]">
    <div class="absolute inset-0 z-0 pointer-events-none h-full" style="background:linear-gradient(to bottom, color-mix(in oklab, var(--color-slate-900) 60%, transparent) 0%, transparent 100%);">
        <img class="h-full w-full" src={image} alt="Hero background" />
    </div>
    <div class="relative z-10 h-full flex flex-col justify-center px-6 sm:px-12 lg:px-24 max-w-7xl mx-auto text-center md:text-left">
        <slot />
    </div>
</section>
