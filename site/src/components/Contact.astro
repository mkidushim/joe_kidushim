---

---
<section id="contact" class="py-10 section-bg-light">
    <div class="text-center text-5xl title-color mb-10">Schedule a Consultation</div>
    <form class="w-full p-3 md:w-1/2 md:mx-auto" method="POST">
        <input type="hidden" name="form-name" value="contact"/>
        <div class="mb-4">
            <label for="name" class="block text-gray-700 font-bold mb-2">Name (required)</label>
            <input type="text" id="name" name="name" required class="w-full px-3 py-2 border rounded">
        </div>
        <div class="mb-4">
            <label for="email" class="block text-gray-700 font-bold mb-2">Email (required)</label>
            <input type="email" id="email" name="email" required class="w-full px-3 py-2 border rounded">
        </div>
        <div class="mb-4">
            <label for="message" class="block text-gray-700 font-bold mb-2">Message (required)</label>
            <textarea id="message" name="message" rows="4" required class="w-full px-3 py-2 border rounded"></textarea>
        </div>
        <button type="submit" class="bg-[#3A6EA5] text-white px-4 py-2 rounded">Submit</button>
    </form>
</section>
